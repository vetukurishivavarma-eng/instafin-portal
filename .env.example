# ─── Required: Set these or the app WILL crash on startup ───
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
JWT_ACCESS_SECRET=generate_a_random_64_char_hex_string
JWT_REFRESH_SECRET=generate_a_different_random_64_char_hex_string

# ─── Required for some features ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
FRONTEND_URL=http://localhost:5173

# ─── Optional: SMTP / Email ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@instafin.com

# ─── Optional: WhatsApp ──────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── Runtime ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
